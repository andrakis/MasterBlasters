{
  "name": "master-blasters",
  "version": "0.1.0",
  "description": "Remake of the 2007 Half-Life 2 mod: Quake rockets x Smash Bros ring-outs on floating platforms. Fixed-tick sim on a worker thread; main thread renders and predicts. Netcode-ready for host-authoritative WebRTC snapshots (phase 2).",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "lint": "tsc --noEmit",
    "test": "node --test \"test/*.test.ts\"",
    "build": "npm run lint && vite build",
    "preview": "vite preview",
    "serve": "node server/index.js",
    "start": "npm run build && npm run serve"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "express": "^4.19.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
